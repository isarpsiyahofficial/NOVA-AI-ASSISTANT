<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#090B11"
                android:centerColor="#121820"
                android:endColor="#2A1A0B"
                android:angle="270" />
        </shape>
    </item>
    <item android:left="-120dp" android:top="80dp">
        <shape android:shape="oval">
            <size android:width="420dp" android:height="420dp" />
            <solid android:color="#18FFB347" />
        </shape>
    </item>
    <item android:right="-150dp" android:bottom="160dp">
        <shape android:shape="oval">
            <size android:width="460dp" android:height="460dp" />
            <solid android:color="#12000000" />
        </shape>
    </item>
</layer-list>
