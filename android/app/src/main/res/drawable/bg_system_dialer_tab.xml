<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape><solid android:color="#332A1A0B"/><corners android:radius="18dp"/><stroke android:width="1dp" android:color="#55FFC15A"/></shape>
    </item>
    <item android:state_selected="true">
        <shape><solid android:color="#24303D"/><corners android:radius="18dp"/><stroke android:width="1dp" android:color="#FFFFA227"/></shape>
    </item>
    <item>
        <shape><solid android:color="#101720"/><corners android:radius="18dp"/><stroke android:width="1dp" android:color="#1EFFC15A"/></shape>
    </item>
</selector>
