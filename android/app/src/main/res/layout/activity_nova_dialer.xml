<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_system_dialer_surface"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingEnd="18dp"
    android:paddingTop="34dp"
    android:paddingBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <Button
            android:id="@+id/topBackButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_system_dialer_card"
            android:text="‹"
            android:textAllCaps="false"
            android:textColor="#FFFFC15A"
            android:textSize="28sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/dialerTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Telefon"
            android:textColor="#FFF3DD"
            android:textSize="30sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/topMenuButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_system_dialer_card"
            android:text="⋮"
            android:textAllCaps="false"
            android:textColor="#FFFFC15A"
            android:textSize="24sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/bg_system_dialer_card"
        android:padding="4dp">

        <Button
            android:id="@+id/recentsShortcutButton"
            style="@style/HiOSTabButton"
            android:layout_weight="1"
            android:background="@drawable/bg_system_dialer_tab"
            android:text="Son aramalar" />

        <Button
            android:id="@+id/contactsShortcutButton"
            style="@style/HiOSTabButton"
            android:layout_weight="1"
            android:background="@drawable/bg_system_dialer_tab"
            android:text="Kişiler" />

        <Button
            android:id="@+id/keypadShortcutButton"
            style="@style/HiOSTabButton"
            android:layout_weight="1"
            android:background="@drawable/bg_system_dialer_tab"
            android:text="Tuş takımı" />
    </LinearLayout>

    <EditText
        android:id="@+id/contactSearchField"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_system_dialer_input"
        android:hint="Kişi ara"
        android:inputType="textPersonName"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="#FFF3DD"
        android:textColorHint="#BDA88A"
        android:textSize="16sp"
        android:visibility="gone" />

    <Button
        android:id="@+id/addContactShortcutButton"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_system_dialer_card"
        android:text="Yeni kişi ekle"
        android:textAllCaps="false"
        android:textColor="#FFFFC15A"
        android:textSize="14sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/dialerNumberField"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_system_dialer_input"
        android:gravity="center"
        android:hint="Numara girin"
        android:inputType="phone"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="#FFF3DD"
        android:textColorHint="#BDA88A"
        android:textSize="26sp" />

    <TextView
        android:id="@+id/listHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:textColor="#FFFFC15A"
        android:textSize="13sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <ScrollView
        android:id="@+id/listScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/listContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <LinearLayout
        android:id="@+id/keypadPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:columnCount="3"
            android:rowCount="4">

            <Button android:id="@+id/dialerDigit1" style="@style/HiOSDialerDigit" android:text="1" />
            <Button android:id="@+id/dialerDigit2" style="@style/HiOSDialerDigit" android:text="2" />
            <Button android:id="@+id/dialerDigit3" style="@style/HiOSDialerDigit" android:text="3" />
            <Button android:id="@+id/dialerDigit4" style="@style/HiOSDialerDigit" android:text="4" />
            <Button android:id="@+id/dialerDigit5" style="@style/HiOSDialerDigit" android:text="5" />
            <Button android:id="@+id/dialerDigit6" style="@style/HiOSDialerDigit" android:text="6" />
            <Button android:id="@+id/dialerDigit7" style="@style/HiOSDialerDigit" android:text="7" />
            <Button android:id="@+id/dialerDigit8" style="@style/HiOSDialerDigit" android:text="8" />
            <Button android:id="@+id/dialerDigit9" style="@style/HiOSDialerDigit" android:text="9" />
            <Button android:id="@+id/dialerDigitStar" style="@style/HiOSDialerDigit" android:text="*" />
            <Button android:id="@+id/dialerDigit0" style="@style/HiOSDialerDigit" android:text="0" />
            <Button android:id="@+id/dialerDigitHash" style="@style/HiOSDialerDigit" android:text="#" />
        </GridLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/dialerDeleteButton"
                android:layout_width="86dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_system_dialer_card"
                android:text="Sil"
                android:textAllCaps="false"
                android:textColor="#FFE2B2" />

            <Space
                android:layout_width="20dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/dialerCallButton"
                android:layout_width="86dp"
                android:layout_height="58dp"
                android:background="@drawable/bg_system_call_green"
                android:text="Ara"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Space
                android:layout_width="20dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/dialerCloseButton"
                android:layout_width="86dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_system_dialer_card"
                android:text="Kapat"
                android:textAllCaps="false"
                android:textColor="#FFE2B2" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
