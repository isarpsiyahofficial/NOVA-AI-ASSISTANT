<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/hiosCallRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_hios_call_wallpaper">

    <LinearLayout
        android:id="@+id/callContentPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="136dp"
        android:paddingBottom="20dp">

        <FrameLayout
            android:id="@+id/avatarFrame"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_gravity="center_horizontal">

            <ImageView
                android:id="@+id/callerPhoto"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:background="@drawable/bg_hios_photo_mask"
                android:clipToOutline="true"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <TextView
                android:id="@+id/callerInitial"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:background="@drawable/bg_hios_photo_mask"
                android:gravity="center"
                android:text="?"
                android:textColor="#FFFFFFFF"
                android:textSize="32sp"
                android:textStyle="bold" />
        </FrameLayout>

        <TextView
            android:id="@+id/callNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:ellipsize="end"
            android:fontFamily="sans-serif-light"
            android:gravity="center"
            android:maxLines="1"
            android:text="KALBÄ°M"
            android:textColor="#FFFFFFFF"
            android:textSize="30sp"
            android:includeFontPadding="false" />

        <TextView
            android:id="@+id/callSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:ellipsize="end"
            android:fontFamily="sans-serif-light"
            android:gravity="center"
            android:maxLines="1"
            android:text="+90 543 178 71 07 | TÃ¼rkiye"
            android:textColor="#E2CCAF"
            android:textSize="17sp"
            android:includeFontPadding="false" />

        <LinearLayout
            android:id="@+id/activeMetaRow"
            android:layout_width="match_parent"
            android:layout_height="34dp"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/hdBadge"
                android:layout_width="32dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_hios_hd_badge"
                android:gravity="center"
                android:text="HD"
                android:textColor="#E7EBF1"
                android:textSize="13sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/callTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:fontFamily="sans-serif"
                android:gravity="center"
                android:textColor="#FFFFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/novaBadge"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_hios_subtle_chip"
            android:gravity="center"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="#FFF3DD"
            android:textSize="11sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/routeBadge"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:visibility="gone" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <LinearLayout
            android:id="@+id/incomingControlsPanel"
            android:layout_width="match_parent"
            android:layout_height="174dp"
            android:gravity="bottom"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/rejectButton"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:drawableTop="@drawable/ic_hios_call_red"
                    android:gravity="center" />

                <TextView
                    android:layout_width="54dp"
                    android:layout_height="64dp"
                    android:gravity="center"
                    android:text="â€¹"
                    android:textColor="#E2CCAF"
                    android:textSize="40sp" />

                <TextView
                    android:id="@+id/messageButton"
                    android:layout_width="76dp"
                    android:layout_height="76dp"
                    android:background="@drawable/bg_hios_message_ring"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center" />

                <TextView
                    android:layout_width="54dp"
                    android:layout_height="64dp"
                    android:gravity="center"
                    android:text="â€º"
                    android:textColor="#E2CCAF"
                    android:textSize="40sp" />

                <TextView
                    android:id="@+id/answerButton"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:drawableTop="@drawable/ic_hios_call_green"
                    android:gravity="center" />
            </LinearLayout>

            <TextView
                android:id="@+id/quickMessageLabel"
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:fontFamily="sans-serif-light"
                android:gravity="center"
                android:text="Kapat ve yanÄ±tla"
                android:textColor="#FFF3DD"
                android:textSize="17sp" />

            <TextView
                android:id="@+id/incomingHandoffButton"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_hios_subtle_chip"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="Nova cevaplasÄ±n"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/activeControlsPanel"
            android:layout_width="match_parent"
            android:layout_height="326dp"
            android:gravity="bottom"
            android:orientation="vertical"
            android:visibility="gone">

            <GridLayout
                android:id="@+id/activeGrid"
                android:layout_width="match_parent"
                android:layout_height="210dp"
                android:columnCount="3"
                android:rowCount="2">

                <TextView android:id="@+id/recordPlaceholder" style="@style/HiosInCallGridButtonExact" android:drawableTop="@drawable/ic_hios_record" android:text="Kayda baÅŸla" />
                <TextView android:id="@+id/muteButton" style="@style/HiosInCallGridButtonExact" android:drawableTop="@drawable/ic_hios_mic_off" android:text="Sesi kapat" />
                <TextView android:id="@+id/holdButton" style="@style/HiosInCallGridButtonExact" android:drawableTop="@drawable/ic_hios_pause" android:text="Beklet" />
                <TextView android:id="@+id/netCallPlaceholder" style="@style/HiosInCallGridButtonExact" android:drawableTop="@drawable/ic_hios_net_call" android:text="Net Arama" />
                <TextView android:id="@+id/addCallButton" style="@style/HiosInCallGridButtonExact" android:drawableTop="@drawable/ic_hios_plus" android:text="Ã‡aÄŸrÄ± ekle" />
                <TextView android:id="@+id/contactsButton" style="@style/HiosInCallGridButtonExact" android:drawableTop="@drawable/ic_hios_more" android:text="DiÄŸer" />
            </GridLayout>

            <GridLayout
                android:id="@+id/moreGrid"
                android:layout_width="match_parent"
                android:layout_height="210dp"
                android:columnCount="3"
                android:rowCount="1"
                android:visibility="gone">

                <TextView android:id="@+id/videoCallButton" style="@style/HiosInCallGridButtonExact" android:drawableTop="@drawable/ic_hios_video" android:text="GÃ¶rÃ¼ntÃ¼lÃ¼ Ar..." />
                <TextView android:id="@+id/contactsActionButton" style="@style/HiosInCallGridButtonExact" android:drawableTop="@drawable/ic_hios_contacts" android:text="KiÅŸiler" />
                <TextView android:id="@+id/moreBackButton" style="@style/HiosInCallGridButtonExact" android:drawableTop="@drawable/ic_hios_chevron_up" android:text="DiÄŸer" />
                <TextView android:id="@+id/handoffButton" style="@style/HiosInCallGridButtonExact" android:drawableTop="@drawable/ic_hios_more" android:text="Nova devralsÄ±n" android:visibility="gone" />
            </GridLayout>

            <LinearLayout
                android:id="@+id/activeBottomBar"
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/speakerButton"
                    android:layout_width="74dp"
                    android:layout_height="74dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:drawableTop="@drawable/ic_hios_speaker"
                    android:gravity="center" />

                <Space android:layout_width="68dp" android:layout_height="1dp" />

                <TextView
                    android:id="@+id/hangupButton"
                    android:layout_width="74dp"
                    android:layout_height="74dp"
                    android:background="@drawable/bg_hios_hangup_round_exact"
                    android:clickable="true"
                    android:focusable="true"
                    android:drawableTop="@drawable/ic_hios_call_end_white"
                    android:gravity="center" />

                <Space android:layout_width="68dp" android:layout_height="1dp" />

                <TextView
                    android:id="@+id/keypadToggleButton"
                    android:layout_width="74dp"
                    android:layout_height="74dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:drawableTop="@drawable/ic_hios_keypad"
                    android:gravity="center" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/keypadContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_hios_call_wallpaper"
        android:orientation="vertical"
        android:paddingStart="36dp"
        android:paddingEnd="36dp"
        android:paddingTop="216dp"
        android:paddingBottom="20dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/keypadPreview"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:fontFamily="sans-serif-light"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="24sp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="368dp"
            android:layout_marginTop="20dp"
            android:columnCount="3"
            android:rowCount="4"
            android:paddingStart="28dp"
            android:paddingEnd="28dp">

            <Button android:id="@+id/digit1" style="@style/HiosKeypadDigitExact" android:text="1&#10;â™§" />
            <Button android:id="@+id/digit2" style="@style/HiosKeypadDigitExact" android:text="2&#10;ABC" />
            <Button android:id="@+id/digit3" style="@style/HiosKeypadDigitExact" android:text="3&#10;DEF" />
            <Button android:id="@+id/digit4" style="@style/HiosKeypadDigitExact" android:text="4&#10;GHI" />
            <Button android:id="@+id/digit5" style="@style/HiosKeypadDigitExact" android:text="5&#10;JKL" />
            <Button android:id="@+id/digit6" style="@style/HiosKeypadDigitExact" android:text="6&#10;MNO" />
            <Button android:id="@+id/digit7" style="@style/HiosKeypadDigitExact" android:text="7&#10;PQRS" />
            <Button android:id="@+id/digit8" style="@style/HiosKeypadDigitExact" android:text="8&#10;TUV" />
            <Button android:id="@+id/digit9" style="@style/HiosKeypadDigitExact" android:text="9&#10;WXYZ" />
            <Button android:id="@+id/digitStar" style="@style/HiosKeypadDigitExact" android:text="*" />
            <Button android:id="@+id/digit0" style="@style/HiosKeypadDigitExact" android:text="0&#10;+" />
            <Button android:id="@+id/digitHash" style="@style/HiosKeypadDigitExact" android:text="#" />
        </GridLayout>

        <Space android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="88dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/keypadCloseButton"
                android:layout_width="74dp"
                android:layout_height="74dp"
                android:clickable="true"
                android:focusable="true"
                android:drawableTop="@drawable/ic_hios_speaker"
                android:gravity="center" />

            <Space android:layout_width="68dp" android:layout_height="1dp" />

            <TextView
                android:id="@+id/keypadHangupButton"
                android:layout_width="74dp"
                android:layout_height="74dp"
                android:background="@drawable/bg_hios_hangup_round_exact"
                android:clickable="true"
                android:focusable="true"
                android:drawableTop="@drawable/ic_hios_call_end_white"
                android:gravity="center" />

            <Space android:layout_width="68dp" android:layout_height="1dp" />

            <TextView
                android:id="@+id/keypadIconButton"
                android:layout_width="74dp"
                android:layout_height="74dp"
                android:clickable="true"
                android:focusable="true"
                android:drawableTop="@drawable/ic_hios_keypad_blue"
                android:gravity="center" />
        </LinearLayout>

        <TextView
            android:id="@+id/keypadDeleteButton"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:visibility="gone" />
    </LinearLayout>
</FrameLayout>
